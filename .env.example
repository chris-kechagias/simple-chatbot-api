# App
APP_NAME="Simple Chatbot API"
VERSION="0.0.0"
DEBUG=False

# Database
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatbot_db

# OpenAI
# System prompt — controls the assistant's personality and behaviour
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_UTILITY_MODEL=gpt-5.4-nano
OPENAI_MAX_COMPLETION_TOKENS=8000
OPENAI_MAX_INPUT_TOKENS=4000
CONTEXT_WINDOW_SIZE=15
OPENAI_SYSTEM_PROMPT="You are a helpful assistant." # See PROMPTS.md for ready-made alternatives